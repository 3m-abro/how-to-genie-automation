              "value": "Bearer YOUR_PICTORY_ACCESS_TOKEN"
            },
            {
              "name": "X-Pictory-User-Id",
              "value": "YOUR_PICTORY_USER_ID"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"videoName\": \"{{ $json.article_title }} - Full Guide\",\n  \"videoDescription\": \"Full explainer video\",\n  \"language\": \"en\",\n  \"videoWidth\": 1920,\n  \"videoHeight\": 1080,\n  \"scenes\": {{ JSON.stringify(($json.explainer?.sections || []).map(s => ({\n    \"text\": s.script,\n    \"voiceOver\": true,\n    \"splitTextOnNewLine\": true,\n    \"splitTextOnPeriod\": true\n  }))) }}\n}",
        "options": {}
      },
      "name": "🎥 Pictory: Create Explainer",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        -176,
        128
