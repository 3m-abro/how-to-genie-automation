        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"title\": \"{{ $json.article_title }}\",\n  \"description\": \"{{ $json.tiktok_reels?.caption || '' }}\",\n  \"script\": \"{{ $json.invideo_storyboard }}\",\n  \"aspect_ratio\": \"9:16\",\n  \"style\": \"trendy\",\n  \"voice\": \"en-US-female-1\",\n  \"music\": \"upbeat\",\n  \"captions\": true,\n  \"duration\": 45,\n  \"output_format\": \"mp4\"\n}",
        "options": {}
      },
      "name": "🎬 InVideo: Create TikTok/Reel",
      "type": "n8n-nodes-base.httpRequest",
