    {
      "parameters": {
        "jsCode": "// Assemble all video assets and build delivery package\nconst jobData = $('Collect Job IDs').item.json;\nconst pictoryResult = $('Fetch Pictory Result').item.json;\nconst klingResult = $('Fetch Kling Result').item.json;\nconst bananaResult = $('Fetch Banana Thumbnails').item.json;\n\nconst videoPackage = {\n  article_title: jobData.article_title,\n  blog_url: jobData.blog_url,\n  generated_at: new Date().toISOString(),\n  videos: {\n    youtube_short: {\n      url: pictoryResult?.data?.videoURL || pictoryResult?.videoURL || 'processing',\n      thumbnail: bananaResult?.modelOutputs?.[0]?.image_base64 ? 'generated' : 'pending',\n      title: jobData.scripts?.youtube_short?.title,\n      description: jobData.scripts?.youtube_short?.description,\n      tags: jobData.scripts?.youtube_short?.tags,\n      status: pictoryResult?.data?.videoURL ? 'ready' : 'processing'\n    },\n    tiktok_reel: {\n      job_id: jobData.invideo_job_id,\n      caption: jobData.scripts?.tiktok_reels?.caption,\n      hashtags: jobData.scripts?.tiktok_reels?.hashtags,\n      status: 'processing'\n    },\n    broll_clip: {\n      url: klingResult?.data?.video_url || 'processing',\n      status: klingResult?.data?.task_status === 'succeed' ? 'ready' : 'processing'\n    }\n  },\n  scripts_saved: true\n};\n\nreturn [{ json: videoPackage }];"
      },
