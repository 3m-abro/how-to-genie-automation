    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.response || '';\nlet scripts;\ntry {\n  const match = raw.match(/```json\\n([\\s\\S]*?)\\n```/) || raw.match(/(\\{[\\s\\S]*\\})/);\n  scripts = JSON.parse(match ? (match[1] || match[0]) : raw);\n} catch(e) {\n  scripts = { parse_error: e.message };\n}\n\n// Build voiceover script for Pictory (full paragraph format)\nconst ytScenes = scripts.youtube_short?.scenes || [];\nconst pictoryScript = ytScenes.map(s => s.voiceover).join(' ');\n\n// Build storyboard text for InVideo\nconst ttScenes = scripts.tiktok_reels?.scenes || [];\nconst invideoStoryboard = ttScenes.map((s, i) => `[${s.time}] ${s.voiceover}`).join('\\n');\n\nreturn [{\n  json: {\n    scripts,\n    pictory_script: pictoryScript,\n    invideo_storyboard: invideoStoryboard,\n    blog_url: scripts.blog_url,\n    article_title: scripts.article_title,\n    youtube_short: scripts.youtube_short,\n    tiktok_reels: scripts.tiktok_reels,\n    explainer: scripts.explainer_video,\n    pinterest_pin: scripts.pinterest_pin\n  }\n}];"
      },
      "name": "📝 Parse Video Scripts",
      "type": "n8n-nodes-base.code",
      "position": [
        -384,
        128
      ],
      "id": "fdbca8e0-e6a4-47fb-9cde-bdf45d883fb7",
      "typeVersion": 2
    },
    {
      "parameters": {
        "url": "https://api.pictory.ai/pictoryapis/v1/video/storyboard",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_PICTORY_ACCESS_TOKEN"
            },
            {
              "name": "X-Pictory-User-Id",
              "value": "YOUR_PICTORY_USER_ID"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"videoName\": \"{{ $json.article_title }}\",\n  \"videoDescription\": \"{{ $json.youtube_short?.description || '' }}\",\n  \"language\": \"en\",\n  \"videoWidth\": 1080,\n  \"videoHeight\": 1920,\n  \"scenes\": {{ JSON.stringify(($json.youtube_short?.scenes || []).map((s,i) => ({\n    \"text\": s.voiceover,\n    \"voiceOver\": true,\n    \"splitTextOnNewLine\": false,\n    \"splitTextOnPeriod\": false\n  }))) }}\n}",
        "options": {}
      },
      "name": "🎥 Pictory: Create YT Short",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        -176,
        -32
      ],
      "id": "b62af567-f427-4c29-8a36-4bfb050fc19c",
      "typeVersion": 4.1,
      "notes": "Pictory API v1. Get credentials at app.pictory.ai/developer. Creates AI video from script."
    },
    {
      "parameters": {
        "url": "https://api.pictory.ai/pictoryapis/v1/video/storyboard",
        "sendHeaders": true,
        "headerParameters": {
