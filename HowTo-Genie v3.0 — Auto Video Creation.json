      "id": "2faa148d-5b76-480c-92a7-6d9435056775",
      "typeVersion": 4.1,
      "notes": "InVideo AI API. Get key at invideo.io/ai/api. Creates TikTok/Reel style video."
    },
    {
      "parameters": {
        "url": "https://api.klingai.com/v1/videos/text2video",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_KLING_API_KEY"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"kling-v1\",\n  \"prompt\": \"{{ ($json.youtube_short?.scenes?.[0]?.visual || 'Educational tutorial scene, bright clean professional setting, text overlays') + ' Style: modern tutorial video, clean minimal aesthetic, bright lighting' }}\",\n  \"negative_prompt\": \"blurry, dark, text errors, watermark\",\n  \"cfg_scale\": 0.5,\n  \"mode\": \"std\",\n  \"aspect_ratio\": \"9:16\",\n  \"duration\": \"5\",\n  \"camera_control\": {\n    \"type\": \"simple\",\n    \"config\": { \"horizontal\": 0, \"vertical\": 0, \"zoom\": 0 }\n  }\n}",
        "options": {}
      },
      "name": "🤖 Kling AI: Generate B-Roll Clip",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        -176,
        432
      ],
      "id": "eef6bc8d-c6dc-4cea-84ab-6bc12ac0e6f2",
      "typeVersion": 4.1,
      "notes": "Kling AI text-to-video for cinematic B-roll. Get key at klingai.com/dev. Generates 5s clip."
    },
    {
      "parameters": {
        "url": "https://api.banana.dev/start/v4/",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_BANANA_API_KEY"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"modelKey\": \"YOUR_BANANA_MODEL_KEY\",\n  \"startOnly\": false,\n  \"modelInputs\": {\n    \"prompt\": \"{{ ($json.youtube_short?.scenes?.[0]?.visual || $json.article_title) + ', photorealistic, professional tutorial blog, bright studio lighting, 8k, sharp focus' }}\",\n    \"negative_prompt\": \"blurry, watermark, text, distorted, dark\",\n    \"num_inference_steps\": 30,\n    \"guidance_scale\": 7.5,\n    \"width\": 1080,\n    \"height\": 1920,\n    \"num_images_per_prompt\": 3\n  }\n}",
        "options": {}
      },
      "name": "🍌 Banana.dev: Generate Thumbnails",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        -176,
        576
      ],
      "id": "9e609d7d-a57c-48ae-b3bf-666121a4896e",
      "typeVersion": 4.1,
      "notes": "Banana.dev runs Stable Diffusion as serverless API. Creates custom video thumbnails."
    },
    {
      "parameters": {
        "jsCode": "// Poll Pictory for job status (it's async)\n// In production, use a Wait + HTTP check loop\nconst pictoryJobId = $('Pictory: Create YT Short').item.json.data?.jobId || \n                     $('Pictory: Create YT Short').item.json.jobId || 'pending';\n                     \nconst invideoJobId = $('InVideo: Create TikTok/Reel').item.json.video_id || \n                     $('InVideo: Create TikTok/Reel').item.json.id || 'pending';\n\nconst klingTaskId = $('Kling AI: Generate B-Roll Clip').item.json.data?.task_id || 'pending';\n\nconst bananaCallId = $('Banana.dev: Generate Thumbnails').item.json.callID || 'pending';\n\nreturn [{\n  json: {\n    pictory_job_id: pictoryJobId,\n    invideo_job_id: invideoJobId,\n    kling_task_id: klingTaskId,\n    banana_call_id: bananaCallId,\n    article_title: $('Parse Video Scripts').item.json.article_title,\n    blog_url: $('Parse Video Scripts').item.json.blog_url,\n    scripts: $('Parse Video Scripts').item.json.scripts,\n    status: 'processing',\n    initiated_at: new Date().toISOString()\n  }\n}];"
      },
