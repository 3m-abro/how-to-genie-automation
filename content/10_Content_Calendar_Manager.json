      {
        "id": "c3d4e5f6-0011-0011-0011-000000000011",
        "name": "🖼️ Extract Image URL",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [1320, 0],
        "parameters": {
          "jsCode": "const pexelsResponse = $input.first().json;\nconst prevData = $('📊 Parse Captions + Build Social Rows').item.json;\n\nconst photos = pexelsResponse.photos || [];\nconst imageUrl = photos[0]?.src?.large || photos[0]?.src?.medium || '';\n\nconst updatedRows = prevData.socialRows.map(row => ({\n  ...row,\n  image_url: imageUrl\n}));\n\nreturn [{ json: { ...prevData, socialRows: updatedRows, imageUrl } }];"
        }
      },
      {
        "id": "c3d4e5f6-0012-0012-0012-000000000012",
