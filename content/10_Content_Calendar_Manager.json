      {
        "id": "c3d4e5f6-0008-0008-0008-000000000008",
        "name": "🤖 Generate Social Captions (Ollama)",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.2,
        "position": [660, 0],
        "parameters": {
          "method": "POST",
          "url": "http://host.docker.internal:11434/v1/chat/completions",
          "sendBody": true,
          "contentType": "json",
          "body": "={\n  \"model\": \"{{ $json.config.OLLAMA_MODEL || 'mistral' }}\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a social media content writer for a how-to blog. Write platform-specific captions for blog posts. Keep tone helpful and practical. No emojis unless specified. Return valid JSON only. No markdown backticks.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Blog post details:\\nTitle: {{ $json.post_title }}\\nURL: {{ $json.post_url }}\\nKeyword: {{ $json.target_keyword }}\\nNiche: {{ $json.niche }}\\n\\nWrite captions for each platform. Return JSON object:\\n{\\n  \\\"pinterest_static\\\": { \\\"caption\\\": string (max 500 chars), \\\"hashtags\\\": string (5 hashtags) },\\n  \\\"pinterest_idea\\\": { \\\"caption\\\": string (max 500 chars), \\\"hashtags\\\": string (5 hashtags) },\\n  \\\"facebook\\\": { \\\"caption\\\": string (max 300 chars), \\\"hashtags\\\": string (3 hashtags) },\\n  \\\"instagram\\\": { \\\"caption\\\": string (max 300 chars), \\\"hashtags\\\": string (10 hashtags) },\\n  \\\"twitter_draft\\\": { \\\"caption\\\": string (max 280 chars), \\\"hashtags\\\": string (2 hashtags) },\\n  \\\"tiktok_script\\\": { \\\"caption\\\": string (30-second spoken script), \\\"hashtags\\\": string (5 hashtags) },\\n  \\\"image_prompt\\\": string (describe a helpful how-to style image for this topic, no text overlay)\\n}\"\n    }\n  ],\n  \"max_tokens\": 2000,\n  \"temperature\": 0.7\n}",
          "options": { "timeout": 90000 }
        }
      },
      {
        "id": "c3d4e5f6-0009-0009-0009-000000000009",
        "name": "📊 Parse Captions + Build Social Rows",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [880, 0],
        "parameters": {
          "jsCode": "const response = $input.first().json;\nconst publishData = $('🔀 Merge Publish Data + Config').item.json;\nconst config = publishData.config;\n\nlet content = response.choices?.[0]?.message?.content || '{}';\ncontent = content.replace(/```json/g, '').replace(/```/g, '').trim();\n\nlet captions = {};\ntry {\n  captions = JSON.parse(content);\n} catch(e) {\n  captions = {};\n}\n\nconst blogPostId = publishData.post_id || publishData.wordpress_post_id || '';\nconst imagePrompt = captions.image_prompt || 'Helpful how-to tutorial image for ' + publishData.post_title;\n\nconst addDays = (dateStr, days) => {\n  const d = new Date(dateStr || new Date());\n  d.setDate(d.getDate() + days);\n  return d.toISOString().split('T')[0];\n};\n\nconst publishDate = publishData.publish_date || new Date().toISOString().split('T')[0];\n\nconst rows = [\n  {\n    blog_post_id: blogPostId,\n    platform: 'Pinterest',\n    post_type: 'Static Pin',\n    scheduled_date: addDays(publishDate, parseInt(config.SOCIAL_POST_DELAY_PINTEREST || 0)),\n    scheduled_time_et: config.SOCIAL_POST_TIME_PINTEREST || '09:00',\n    caption: captions.pinterest_static?.caption || '',\n    hashtags: captions.pinterest_static?.hashtags || '',\n    image_prompt: imagePrompt,\n    image_url: '',\n    status: 'DRAFT',\n    blotato_post_id: '',\n    engagement_notes: ''\n  },\n  {\n    blog_post_id: blogPostId,\n    platform: 'Facebook',\n    post_type: 'Link Post',\n    scheduled_date: addDays(publishDate, parseInt(config.SOCIAL_POST_DELAY_FACEBOOK || 0)),\n    scheduled_time_et: config.SOCIAL_POST_TIME_FACEBOOK || '10:00',\n    caption: captions.facebook?.caption || '',\n    hashtags: captions.facebook?.hashtags || '',\n    image_prompt: imagePrompt,\n    image_url: '',\n    status: 'DRAFT',\n    blotato_post_id: '',\n    engagement_notes: ''\n  },\n  {\n    blog_post_id: blogPostId,\n    platform: 'Instagram',\n    post_type: 'Image Post',\n    scheduled_date: addDays(publishDate, parseInt(config.SOCIAL_POST_DELAY_INSTAGRAM || 1)),\n    scheduled_time_et: config.SOCIAL_POST_TIME_INSTAGRAM || '11:00',\n    caption: captions.instagram?.caption || '',\n    hashtags: captions.instagram?.hashtags || '',\n    image_prompt: imagePrompt,\n    image_url: '',\n    status: 'DRAFT',\n    blotato_post_id: '',\n    engagement_notes: ''\n  },\n  {\n    blog_post_id: blogPostId,\n    platform: 'Pinterest',\n    post_type: 'Idea Pin',\n    scheduled_date: addDays(publishDate, parseInt(config.SOCIAL_POST_DELAY_PINTEREST_IDEA || 7)),\n    scheduled_time_et: config.SOCIAL_POST_TIME_PINTEREST || '09:00',\n    caption: captions.pinterest_idea?.caption || '',\n    hashtags: captions.pinterest_idea?.hashtags || '',\n    image_prompt: imagePrompt,\n    image_url: '',\n    status: 'DRAFT',\n    blotato_post_id: '',\n    engagement_notes: ''\n  }\n];\n\nconst manualRows = [\n  {\n    blog_post_id: blogPostId,\n    platform: 'Twitter/X',\n    draft_content: (captions.twitter_draft?.caption || '') + '\\n\\nLink: ' + publishData.post_url + '\\n' + (captions.twitter_draft?.hashtags || ''),\n    created_date: new Date().toISOString().split('T')[0],\n    posted: 'N',\n    notes: 'Auto-generated draft'\n  },\n  {\n    blog_post_id: blogPostId,\n    platform: 'TikTok',\n    draft_content: 'SCRIPT: ' + (captions.tiktok_script?.caption || '') + '\\n\\nHASHTAGS: ' + (captions.tiktok_script?.hashtags || ''),\n    created_date: new Date().toISOString().split('T')[0],\n    posted: 'N',\n    notes: 'Record 30-sec video and post manually'\n  }\n];\n\nreturn [{ json: { socialRows: rows, manualRows, config, publishData, imagePrompt } }];"
        }
      },
      {
        "id": "c3d4e5f6-0010-0010-0010-000000000010",
        "name": "🖼️ Fetch Image from Pexels",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.2,
        "position": [1100, 0],
        "parameters": {
          "method": "GET",
          "url": "https://api.pexels.com/v1/search",
          "sendQuery": true,
          "queryParameters": {
            "parameters": [
              { "name": "query", "value": "={{ $json.publishData.target_keyword }}" },
