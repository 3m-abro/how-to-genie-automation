        "id": "c3d4e5f6-0030-0030-0030-000000000030",
        "name": "🔍 Filter Next 7 Days",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [660, 800],
        "parameters": {
          "jsCode": "const rows = $input.all();\nconst config = $('⚙️ Load Config (Gap Check)').item.json;\nconst now = new Date();\nconst in7Days = new Date(now);\nin7Days.setDate(now.getDate() + 7);\n\nconst upcoming = rows.filter(r => {\n  if (!r.json.publish_date) return false;\n  const d = new Date(r.json.publish_date);\n  return d >= now && d <= in7Days;\n});\n\nconst minArticles = parseInt(config.MIN_PLANNED_ARTICLES || 3);\nconst weekOf = in7Days.toISOString().split('T')[0];\n\nreturn [{ json: {\n  count: upcoming.length,\n  minArticles,\n  weekOf,\n  gap: upcoming.length < minArticles,\n  config\n}}];"
        }
      },
