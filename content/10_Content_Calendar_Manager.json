      {
        "id": "c3d4e5f6-0023-0023-0023-000000000023",
        "name": "📤 Prepare Blotato Payload",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [1760, 400],
        "parameters": {
          "jsCode": "const items = $input.all();\nconst config = $('⚙️ Load Config (Daily)').item.json;\n\nconst postItem = items.find(i => i.json.platform) || items[0];\nconst imageItem = items.find(i => i.json.photos) || null;\n\nconst imageUrl = imageItem?.json?.photos?.[0]?.src?.large || postItem.json.image_url || '';\n\nconst platformKeyMap = {\n  'Pinterest': config.BLOTATO_PROFILE_PINTEREST || 'pinterest_htg',\n  'Facebook': config.BLOTATO_PROFILE_FACEBOOK || 'facebook_htg',\n  'Instagram': config.BLOTATO_PROFILE_INSTAGRAM || 'instagram_htg',\n  'TikTok': config.BLOTATO_PROFILE_TIKTOK || 'tiktok_htg'\n};\n\nconst platform = postItem.json.platform;\nconst profileKey = platformKeyMap[platform] || 'default';\n\nreturn [{ json: {\n  profileKey,\n  caption: postItem.json.caption + '\\n\\n' + postItem.json.hashtags,\n  imageUrl,\n  platform,\n  rowData: postItem.json,\n  config\n}}];"
        }
      },
