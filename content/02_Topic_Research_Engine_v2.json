    {
      "id": "a1b2c3d4-0010-0010-0010-000000000010",
      "name": "💾 Write to Reddit Cache",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1540, 100],
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst subreddit = $('🔀 Use Cache or API?').item.json.subreddit;\nconst config = $('🔀 Use Cache or API?').item.json.config;\nconst now = new Date().toISOString();\n\nconst posts = (response.data?.children || response.posts || []).slice(0, 50);\n\nconst rows = posts.map(p => ({\n  json: {\n    subreddit,\n    post_title: p.data?.title || p.title || '',\n    post_url: p.data?.url || p.url || '',\n    score: p.data?.score || p.score || 0,\n    num_comments: p.data?.num_comments || p.num_comments || 0,\n    niche: config.SITE_NICHE || 'general',\n    fetched_at: now\n  }\n}));\n\nreturn rows;"
      }
    },
