    {
      "id": "a1b2c3d4-0021-0021-0021-000000000021",
      "name": "🌐 Call ATP API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1320, 700],
      "parameters": {
        "method": "GET",
        "url": "={{ $json.config.RAPIDAPI_ATP_BASE }}/search",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "keyword", "value": "={{ $json.keyword }}" },
            { "name": "country", "value": "us" },
            { "name": "language", "value": "en" }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-RapidAPI-Key", "value": "={{ $json.config.RAPIDAPI_KEY }}" },
            { "name": "X-RapidAPI-Host", "value": "={{ $json.config.RAPIDAPI_ATP_HOST }}" }
          ]
        },
        "options": { "timeout": 30000 }
      }
    },
    {
      "id": "a1b2c3d4-0022-0022-0022-000000000022",
      "name": "💾 Parse + Save ATP Cache",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1540, 700],
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst keyword = $('🔀 ATP Cache or API?').item.json.keyword;\nconst now = new Date().toISOString();\n\nconst questions = [];\nconst addQuestions = (arr, type) => {\n  if (Array.isArray(arr)) {\n    arr.forEach(q => {\n      if (q && typeof q === 'string') {\n        questions.push({ keyword, question: q, search_type: type, fetched_at: now, used: 'N' });\n      } else if (q && q.query) {\n        questions.push({ keyword, question: q.query, search_type: type, fetched_at: now, used: 'N' });\n      }\n    });\n  }\n};\n\naddQuestions(response.questions?.data, 'question');\naddQuestions(response.how?.data, 'how');\naddQuestions(response.what?.data, 'what');\naddQuestions(response.why?.data, 'why');\naddQuestions(response.which?.data, 'which');\naddQuestions(response.when?.data, 'when');\naddQuestions(response.are?.data, 'are');\n\nreturn questions.slice(0, 100).map(q => ({ json: q }));"
      }
    },
