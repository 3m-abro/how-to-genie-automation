		{
			"parameters": {
				"jsCode": "const blocked = ['alcohol', 'pork', 'gambling', 'dating', 'casino', 'beer', 'wine', 'spirits', 'bacon', 'ham', 'lottery'];\nreturn $input.all().filter(item => {\n  const text = (item.json.title + ' ' + item.json.target_keyword + ' ' + (item.json.reason || '')).toLowerCase();\n  return !blocked.some(word => text.includes(word));\n});"
			},
