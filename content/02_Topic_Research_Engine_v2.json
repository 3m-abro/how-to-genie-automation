				"jsCode": "const ideas = $input.all();\nconst config = $('⚙️ Load Config (Planning)').item.json;\n\n// Sort by score descending\nconst sorted = ideas.sort((a, b) => (parseFloat(b.json.score) || 0) - (parseFloat(a.json.score) || 0));\nconst top3 = sorted.slice(0, 3);\n\n// Calculate next Mon/Wed/Fri\nconst now = new Date();\nconst day = now.getDay(); // 0=Sun, 1=Mon\nconst daysUntilMonday = day === 1 ? 0 : (8 - day) % 7;\nconst monday = new Date(now);\nmonday.setDate(now.getDate() + daysUntilMonday);\n\nconst wednesday = new Date(monday);\nwednesday.setDate(monday.getDate() + 2);\nconst friday = new Date(monday);\nfriday.setDate(monday.getDate() + 4);\n\nconst publishDates = [\n  monday.toISOString().split('T')[0],\n  wednesday.toISOString().split('T')[0],\n  friday.toISOString().split('T')[0]\n];\n\nconst weekNum = Math.ceil((monday - new Date(monday.getFullYear(), 0, 1)) / (7 * 24 * 60 * 60 * 1000));\n\nreturn top3.map((item, i) => ({\n  json: {\n    week_number: weekNum,\n    publish_date: publishDates[i],\n    topic_title: item.json.title,\n    niche: item.json.niche,\n    target_keyword: item.json.target_keyword,\n    status: 'PLANNED',\n    word_count_target: 1500,\n    article_url: '',\n    wordpress_post_id: '',\n    seo_score: '',\n    qc_score: '',\n    notes: 'Auto-planned from backlog score: ' + (item.json.score || ''),\n    original_row_id: item.json.row_number || i,\n    config\n  }\n}));"
			},
