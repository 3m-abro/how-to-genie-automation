    {
      "id": "a1b2c3d4-0013-0013-0013-000000000013",
      "name": "🤖 Score Topics with Ollama",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2200, 0],
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:11434/v1/chat/completions",
        "sendBody": true,
        "contentType": "json",
        "body": "={\n  \"model\": \"{{ $('⚙️ Load Config').item.json.OLLAMA_MODEL || 'mistral' }}\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a content strategist for a how-to blog. Analyze Reddit posts and generate blog topic ideas. Score each idea 1-100. Return valid JSON only. No markdown.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Subreddit: {{ $json.subreddit }}\\n\\nTop posts this week:\\n{{ $input.all().slice(0,20).map(i => i.json.post_title || i.json.title || '').filter(t => t).map((t,i) => (i+1) + '. ' + t).join('\\n') }}\\n\\nGenerate 5 blog topic ideas based on these posts. Return JSON array: [{\\\"title\\\": string, \\\"target_keyword\\\": string, \\\"score\\\": number, \\\"niche\\\": string, \\\"reason\\\": string}]\"\n    }\n  ],\n  \"max_tokens\": 1000,\n  \"temperature\": 0.7\n}",
        "options": { "timeout": 60000 }
      }
    },
    {
      "id": "a1b2c3d4-0014-0014-0014-000000000014",
      "name": "📊 Parse Ollama Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2420, 0],
      "parameters": {
        "jsCode": "const response = $input.first().json;\nlet content = response.choices?.[0]?.message?.content || '';\ncontent = content.replace(/```json/g, '').replace(/```/g, '').trim();\n\nlet ideas = [];\ntry {\n  ideas = JSON.parse(content);\n} catch(e) {\n  const match = content.match(/\\[.*\\]/s);\n  if (match) {\n    try { ideas = JSON.parse(match[0]); } catch(e2) { ideas = []; }\n  }\n}\n\nreturn ideas.map(idea => ({ json: {\n  ...idea,\n  status: 'UNSCHEDULED',\n  source: 'reddit',\n  created_at: new Date().toISOString()\n}}));"
      }
    },
    {
      "id": "a1b2c3d4-0015-0015-0015-000000000015",
      "name": "✅ Halal Filter",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2640, 0],
      "parameters": {
        "jsCode": "const blocked = ['alcohol', 'pork', 'gambling', 'dating', 'casino', 'beer', 'wine', 'spirits', 'bacon', 'ham', 'lottery'];\nreturn $input.all().filter(item => {\n  const text = (item.json.title + ' ' + item.json.target_keyword + ' ' + (item.json.reason || '')).toLowerCase();\n  return !blocked.some(word => text.includes(word));\n});"
      }
    },
