    {
      "id": "a1b2c3d4-0007-0007-0007-000000000007",
      "name": "🔍 Cache Fresh?",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, 0],
      "parameters": {
        "jsCode": "const rows = $input.all();\nconst subreddit = $('📋 Get Subreddit List').item.json.subreddit;\nconst config = $('📋 Get Subreddit List').item.json.config;\nconst ttlDays = parseInt(config.REDDIT_CACHE_TTL_DAYS || 7);\nconst now = new Date();\n\nconst freshRows = rows.filter(r => {\n  if (!r.json.fetched_at) return false;\n  const fetched = new Date(r.json.fetched_at);\n  const ageDays = (now - fetched) / (1000 * 60 * 60 * 24);\n  return ageDays < ttlDays;\n});\n\nif (freshRows.length > 0) {\n  return [{ json: { \n    useCached: true, \n    subreddit, \n    config,\n    posts: freshRows.map(r => r.json),\n    source: 'cache'\n  }}];\n} else {\n  return [{ json: { useCached: false, subreddit, config, source: 'api' }}];\n}"
      }
    },
    {
      "id": "a1b2c3d4-0008-0008-0008-000000000008",
