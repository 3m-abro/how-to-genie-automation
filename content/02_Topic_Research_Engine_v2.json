    {
      "id": "a1b2c3d4-0019-0019-0019-000000000019",
      "name": "🔍 ATP Cache Fresh?",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, 600],
      "parameters": {
        "jsCode": "const rows = $input.all();\nconst keyword = $('📋 Get ATP Seeds').item.json.keyword;\nconst config = $('⚙️ Load Config (Planning)').item.json;\nconst ttlDays = parseInt(config.ATP_CACHE_TTL_DAYS || 90);\nconst now = new Date();\n\nconst freshRows = rows.filter(r => {\n  if (!r.json.fetched_at) return false;\n  const fetched = new Date(r.json.fetched_at);\n  const ageDays = (now - fetched) / (1000 * 60 * 60 * 24);\n  return ageDays < ttlDays;\n});\n\nif (freshRows.length > 0) {\n  return [{ json: { useCached: true, keyword, config, questions: freshRows.map(r => r.json) }}];\n} else {\n  return [{ json: { useCached: false, keyword, config }}];\n}"
      }
    },
    {
      "id": "a1b2c3d4-0020-0020-0020-000000000020",
      "name": "🔀 ATP Cache or API?",
      "type": "n8n-nodes-base.if",
