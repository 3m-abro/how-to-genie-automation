    {
      "parameters": {
        "jsCode": "// One row per post: Source URL, Date (content day), per-format columns, Timestamp. Column contract: Source URL, Date, Timestamp, twitter_text, linkedin_text, ig_carousel_json, podcast_script, community_text.\nconst config = $('⚙️ Load Config').item.json;\nconst filterRow = $('Filter today\\'s post').item.json;\nconst mergeItems = $input.all().map(i => i.json);\nconst sourceUrl = filterRow['WP URL'] || filterRow.wp_url || filterRow.url || '';\nconst contentDate = (filterRow.date || filterRow.Date || '').toString().slice(0, 10);\nconst timestamp = new Date().toISOString();\nconst row = { 'Source URL': sourceUrl, 'Date': contentDate, 'Timestamp': timestamp };\nfor (const item of mergeItems) {\n  const f = item.format;\n  if (f === 'twitter') row.twitter_text = item.success && item.data ? (item.data.tweets ? item.data.tweets.map(t => (t.text || t)).join('\\n') : JSON.stringify(item.data)) : (item.error?.message || '');\n  else if (f === 'linkedin') row.linkedin_text = item.success && item.data ? (item.data.article_body || item.data.body || JSON.stringify(item.data)) : (item.error?.message || '');\n  else if (f === 'ig_carousel') row.ig_carousel_json = item.success && item.data ? JSON.stringify(item.data) : (item.error?.message || '');\n  else if (f === 'podcast') row.podcast_script = item.success && item.data ? (item.data.full_script || item.data.script || JSON.stringify(item.data)) : (item.error?.message || '');\n  else if (f === 'community') row.community_text = item.success && item.data ? JSON.stringify(item.data) : (item.error?.message || '');\n}\nreturn [{ json: row }];"
      },
