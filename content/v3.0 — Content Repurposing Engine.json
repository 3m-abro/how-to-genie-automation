    {
      "parameters": {
        "jsCode": "// Clean and prepare article for repurposing\nconst post = $input.first().json[0] || $input.first().json;\nconst rawContent = post?.content?.rendered || post?.content || '';\n\n// Strip HTML tags\nconst cleanContent = rawContent\n  .replace(/<[^>]*>/g, ' ')\n  .replace(/&nbsp;/g, ' ')\n  .replace(/&amp;/g, '&')\n  .replace(/&lt;/g, '<')\n  .replace(/&gt;/g, '>')\n  .replace(/\\s+/g, ' ')\n  .trim();\n\n// Extract key sections\nconst title = post?.title?.rendered || 'Article';\nconst url = post?.link || 'https://howtogenie.com';\nconst excerpt = post?.excerpt?.rendered?.replace(/<[^>]*>/g,'').trim() || cleanContent.substring(0,200);\nconst wordCount = cleanContent.split(' ').length;\n\n// Extract headings for structure\nconst headingMatches = rawContent.match(/<h[23][^>]*>(.*?)<\\/h[23]>/gi) || [];\nconst headings = headingMatches.map(h => h.replace(/<[^>]*>/g,'').trim());\n\nreturn [{ json: {\n  title,\n  url,\n  excerpt,\n  clean_content: cleanContent.substring(0, 5000), // Limit for AI context\n  word_count: wordCount,\n  headings,\n  post_id: post?.id,\n  categories: post?.categories || [],\n  tags: post?.tags || []\n}}];"
      },
      "name": "🧹 Clean & Extract Article",
      "type": "n8n-nodes-base.code",
      "position": [
        536,
        224
      ],
      "id": "ecc120ac-199b-4914-894a-3b7334cbdaa5",
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "const article = $input.first().json;\nconst config = $('⚙️ Load Config').item.json;\nconst raw = (config.REPURPOSE_FORMATS || 'twitter,linkedin,ig_carousel,podcast,community').toString().trim();\nconst enabledFormats = raw ? raw.split(',').map(s => s.trim()).filter(Boolean) : [];\nconst allFormats = ['twitter','linkedin','ig_carousel','podcast','community'];\nreturn allFormats.map(f => ({ json: { format: f, skip: !enabledFormats.includes(f), ...article } }));"
      },
