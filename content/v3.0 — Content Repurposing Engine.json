    {
      "parameters": {
        "jsCode": "const config = $('⚙️ Load Config').item.json;\nconst filterRow = $('Filter today\\'s post').item.json;\nconst slug = filterRow.slug || (filterRow['WP URL'] || '').split('/').filter(Boolean).pop() || '';\nconst contentDate = (filterRow.date || filterRow.Date || '').toString().slice(0, 10) || new Date().toLocaleDateString('en-CA', { timeZone: config.CONTENT_DAY_TIMEZONE || config.TIMEZONE || 'UTC' });\nconst key = `${slug}|${contentDate}`;\nconst rows = $input.all().map(i => i.json);\nconst dateCol = Object.keys(rows[0] || {}).find(k => k.toLowerCase() === 'date') || 'Date';\nconst urlCol = Object.keys(rows[0] || {}).find(k => k.toLowerCase().includes('url') || k === 'Source URL') || 'Source URL';\nconst already = rows.some(r => {\n  const rSlug = (r[urlCol] || r['Source URL'] || '').split('/').filter(Boolean).pop();\n  const rDate = String(r[dateCol] || r['Date'] || '').slice(0, 10);\n  return `${rSlug}|${rDate}` === key;\n});\nreturn [{ json: { alreadyRepurposed: already, slug, contentDate, ...filterRow } }];"
      },
