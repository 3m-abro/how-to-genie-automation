    {
      "parameters": {
        "jsCode": "// Build content index with metadata\nconst allPosts = $input.all().slice(1); // Skip header row\n\nconst contentIndex = allPosts.map((item, idx) => {\n  const row = item.json;\n  return {\n    id: idx + 1,\n    title: row['Title'],\n    url: row['WP URL'],\n    keyword: row['Keyword'],\n    tags: (row['Tags'] || '').split(',').map(t => t.trim()),\n    categories: (row['Categories'] || '').split(',').map(c => c.trim()),\n    language: 'en', // Will enhance with multilingual data\n    published_date: row['Date']\n  };\n});\n\n// Calculate content clusters by category and tags\nconst clusters = {};\ncontentIndex.forEach(post => {\n  post.categories.forEach(cat => {\n    if (!clusters[cat]) clusters[cat] = [];\n    clusters[cat].push(post.id);\n  });\n});\n\nreturn [{\n  json: {\n    total_posts: contentIndex.length,\n    content_index: contentIndex,\n    clusters: clusters,\n    languages: ['en', 'es', 'pt-BR', 'de', 'fr', 'hi', 'id', 'ar', 'ja'],\n    scan_date: new Date().toISOString()\n  }\n}];"
      },
      "name": "🗂️ Build Content Index",
      "type": "n8n-nodes-base.code",
      "position": [
        -1760,
        -16
      ],
      "id": "cf68a765-e732-4f48-b2ae-5ec96e495504",
