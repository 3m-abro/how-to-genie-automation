    {
      "parameters": {
        "jsCode": "// Parse injected content\nconst raw = $input.first().json.response || '';\nconst postData = $('Parse Link Recommendations').item.json;\n\nlet injectionResult;\ntry {\n  const match = raw.match(/```json\\n([\\s\\S]*?)\\n```/) || raw.match(/(\\{[\\s\\S]*\\})/);\n  injectionResult = JSON.parse(match ? (match[1] || match[0]) : raw);\n} catch(e) {\n  injectionResult = {\n    updated_content: $('Fetch Current Post Content').item.json,\n    links_injected: [],\n    parse_error: e.message\n  };\n}\n\nreturn [{\n  json: {\n    post_id: postData.post_id,\n    post_url: postData.post_url,\n    updated_content: injectionResult.updated_content,\n    links_injected: injectionResult.links_injected || [],\n    total_links_added: injectionResult.total_links_added || 0,\n    link_density_check: injectionResult.link_density_check,\n    natural_flow_score: injectionResult.natural_flow_score || 0,\n    ready_to_update: injectionResult.total_links_added > 0,\n    updated_at: new Date().toISOString()\n  }\n}];"
