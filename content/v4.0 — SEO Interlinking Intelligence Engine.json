    {
      "parameters": {
        "jsCode": "// Parse AI recommendations and build link injection plan\nconst raw = $input.first().json.response || '';\nconst postData = $input.first().json.content_index[0];\n\nlet linkPlan;\ntry {\n  const match = raw.match(/```json\\n([\\s\\S]*?)\\n```/) || raw.match(/(\\{[\\s\\S]*\\})/);\n  linkPlan = JSON.parse(match ? (match[1] || match[0]) : raw);\n} catch(e) {\n  linkPlan = {\n    current_post_id: postData?.id,\n    recommended_links: [],\n    parse_error: e.message\n  };\n}\n\nreturn [{\n  json: {\n    post_id: linkPlan.current_post_id,\n    post_title: postData?.title,\n    post_url: postData?.url,\n    topical_cluster: linkPlan.topical_cluster,\n    cluster_role: linkPlan.cluster_role,\n    orphan_risk: linkPlan.orphan_risk,\n    links_to_add: linkPlan.recommended_links || [],\n    total_links: linkPlan.recommended_links?.length || 0,\n    analysis_date: new Date().toISOString()\n  }\n}];"
      },
