      },
      "name": "🌐 Ping WordPress",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        -224,
        176
      ],
      "id": "48679bde-71b4-4622-a876-df765505dd20",
      "alwaysOutputData": false
    },
    {
      "parameters": {
        "jsCode": "// Assemble full health report\nconst healthStatus = $('📊 Evaluate Health Status').item.json;\n\nlet ollamaOk = false;\nlet wpOk = false;\n\ntry {\n  const ollama = $('🤖 Ping Ollama').item.json;\n  ollamaOk = Array.isArray(ollama.models) || ollama.models !== undefined;\n} catch(e) { ollamaOk = false; }\n\ntry {\n  const wp = $('🌐 Ping WordPress').item.json;\n  wpOk = Array.isArray(wp) && wp.length > 0;\n} catch(e) { wpOk = false; }\n\nconst services = [\n  { name: 'Master Orchestrator', status: healthStatus.results[0]?.status || 'UNKNOWN' },\n  { name: 'Ollama AI Engine', status: ollamaOk ? 'OK' : 'DOWN' },\n  { name: 'WordPress Site', status: wpOk ? 'OK' : 'DOWN' }\n];\n\nconst critical = services.filter(s => s.status === 'DOWN' || s.status === 'MISSED');\nconst allGreen = critical.length === 0;\n\nconst reportLines = services.map(s => `${s.status === 'OK' ? '✅' : '🔴'} ${s.name}: ${s.status}`).join('\\n');\n\nreturn [{ json: {\n  all_green: allGreen,\n  services,\n  critical_count: critical.length,\n  report: reportLines,\n  check_time: healthStatus.check_time,\n  alert_needed: !allGreen\n}}];"
      },
      "name": "📋 Build Health Report",
      "type": "n8n-nodes-base.code",
