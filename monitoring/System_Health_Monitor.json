      "name": "🕘 Daily Health Check (9:05AM)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        -896,
        368
      ],
      "id": "bcf167cf-f351-4887-8335-7cc18886fccd",
      "notes": "Fires 5 min after orchestrator. Verifies everything ran."
    },
    {
      "parameters": {
        "jsCode": "// Check all critical workflows ran in last 25 hours\nconst execData = $input.first().json;\nconst executions = execData.data || [];\n\nconst now = new Date();\nconst threshold = 25 * 60 * 60 * 1000; // 25 hours in ms\n\nconst results = [];\nlet allHealthy = true;\n\n// Check if orchestrator ran\nif (executions.length === 0) {\n  results.push({ workflow: 'Master Orchestrator', status: 'MISSED', last_run: 'Never or >25hrs ago' });\n  allHealthy = false;\n} else {\n  const lastRun = new Date(executions[0].startedAt);\n  const age = now - lastRun;\n  const status = age < threshold ? 'OK' : 'MISSED';\n  if (status === 'MISSED') allHealthy = false;\n  results.push({ \n    workflow: 'Master Orchestrator', \n    status, \n    last_run: lastRun.toISOString(),\n    age_hours: Math.round(age / 3600000)\n  });\n}\n\n// Disk space check via VPS (approximate - adjust path)\nconst diskWarning = false; // Will be checked in next node\n\nreturn [{ json: {\n  all_healthy: allHealthy,\n  check_time: now.toISOString(),\n  results,\n  summary: allHealthy ? 'All systems nominal' : `${results.filter(r=>r.status==='MISSED').length} workflow(s) missed their schedule`\n}}];"
      },
      "name": "📊 Evaluate Health Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -224,
        368
      ],
      "id": "89dfa8b6-19cc-499b-b226-ec01a376744a"
    },
