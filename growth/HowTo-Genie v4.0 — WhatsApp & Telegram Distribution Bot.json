        "jsCode": "const items = $input.all();\nconst active = items.filter(i => {\n  const s = (i.json.Status || i.json.status || '').toString().toLowerCase().trim();\n  return s === 'active';\n});\nif (active.length === 0) {\n  return [{ json: { zeroActiveSubscribers: true, count: 0 } }];\n}\nreturn active.map(a => ({ json: { ...a.json, zeroActiveSubscribers: false } }));"
