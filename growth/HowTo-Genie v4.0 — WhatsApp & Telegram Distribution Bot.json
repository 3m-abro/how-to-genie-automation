    {
      "parameters": {
        "jsCode": "// Parse messaging content\nconst raw = $input.first().json.response || '';\nconst postData = $('Get Today\\'s Post').item.json;\n\nlet messaging;\ntry {\n  const match = raw.match(/```json\\n([\\s\\S]*?)\\n```/) || raw.match(/(\\{[\\s\\S]*\\})/);\n  messaging = JSON.parse(match ? (match[1] || match[0]) : raw);\n} catch(e) {\n  messaging = {\n    whatsapp_1to1: 'Check out our latest post: ' + postData['WP URL'],\n    telegram_channel: '**New Post:** ' + postData['Title'] + '\\n\\nRead: ' + postData['WP URL'],\n    parse_error: e.message\n  };\n}\n\nreturn [{\n  json: {\n    post_url: postData['WP URL'],\n    post_title: postData['Title'],\n    messaging_content: messaging,\n    distribution_date: new Date().toISOString()\n  }\n}];"
      },
      "name": "📋 Parse Messaging Content",
      "type": "n8n-nodes-base.code",
      "position": [
        -560,
        64
      ],
      "id": "8cb8bb31-274d-4753-b246-d5264353055b",
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "// Build subscriber batches with personalized content\nconst subscribers = $('Load Messaging Subscribers').all().slice(1); // Skip header\nconst content = $('Parse Messaging Content').item.json;\n\nreturn subscribers.map(sub => {\n  const row = sub.json;\n  const phone = row['Phone'];\n  const platform = row['Platform'] || 'whatsapp';\n  const language = row['Language'] || 'en';\n  const timezone = row['Timezone'] || 'UTC';\n  const preferences = row['Preferences'] || 'daily';\n  const status = row['Status'] || 'active';\n  \n  if (status !== 'active') return null;\n  \n  // Get content in subscriber's language\n  let message;\n  if (platform.toLowerCase() === 'whatsapp') {\n    message = language !== 'en' && content.messaging_content.translations?.[language]?.whatsapp_1to1\n      ? content.messaging_content.translations[language].whatsapp_1to1\n      : content.messaging_content.whatsapp_1to1;\n  } else {\n    message = language !== 'en' && content.messaging_content.translations?.[language]?.telegram_channel\n      ? content.messaging_content.translations[language].telegram_channel\n      : content.messaging_content.telegram_channel;\n  }\n  \n  return {\n    json: {\n      phone: phone,\n      platform: platform.toLowerCase(),\n      language: language,\n      message: message,\n      post_url: content.post_url,\n      post_title: content.post_title,\n      telegram_button: content.messaging_content.telegram_button\n    }\n  };\n}).filter(Boolean);"
      },
