    {
      "parameters": {
        "jsCode": "// Parse incoming message\nconst body = $input.first().json.body || $input.first().json;\nconst platform = $node.name.includes('WhatsApp') ? 'whatsapp' : 'telegram';\n\nlet message, userId, userName;\n\nif (platform === 'whatsapp') {\n  const entry = body.entry?.[0]?.changes?.[0]?.value;\n  message = entry?.messages?.[0]?.text?.body || '';\n  userId = entry?.messages?.[0]?.from || '';\n  userName = entry?.contacts?.[0]?.profile?.name || 'User';\n} else {\n  message = body.message?.text || '';\n  userId = body.message?.chat?.id || '';\n  userName = body.message?.from?.first_name || 'User';\n}\n\nconst command = message.toLowerCase().trim();\n\nreturn [{\n  json: {\n    platform,\n    user_id: userId,\n    user_name: userName,\n    message: message,\n    command: command,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
