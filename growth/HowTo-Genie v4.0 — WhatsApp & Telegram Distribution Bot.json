      "parameters": {
        "jsCode": "// Parse bot response\nconst raw = $input.first().json.response || '';\nconst userData = $input.first().json;\n\nlet botResponse;\ntry {\n  const match = raw.match(/```json\\n([\\s\\S]*?)\\n```/) || raw.match(/(\\{[\\s\\S]*\\})/);\n  botResponse = JSON.parse(match ? (match[1] || match[0]) : raw);\n} catch(e) {\n  botResponse = {\n    response_message: 'Thanks for your message! Use /help to see what I can do. 🧞‍♂️',\n    action: 'none'\n  };\n}\n\nreturn [{\n  json: {\n    ...userData,\n    bot_response: botResponse.response_message,\n    action: botResponse.action,\n    action_data: botResponse.action_data || {},\n    quick_replies: botResponse.quick_replies || []\n  }\n}];"
