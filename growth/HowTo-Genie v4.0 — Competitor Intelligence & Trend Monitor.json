      "notes": "Reddit JSON API. No auth required for public data."
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst out = [];\nfor (let i = 0; i < items.length; i++) {\n  const data = items[i].json?.data?.children || [];\n  const subreddit = $('🔀 Route by Type').item(i).json?.subreddit || 'reddit';\n  data.filter(post => post.data && post.data.ups >= 100).forEach(post => {\n    out.push({ json: { source: 'reddit', title: post.data.title, url: 'https://reddit.com' + post.data.permalink, published: new Date(post.data.created_utc * 1000).toISOString(), detected_at: new Date().toISOString() } });\n  });\n}\nreturn out.length ? out : [{ json: { source: 'reddit', title: '', url: '', published: '', detected_at: new Date().toISOString() } }];"
      },
