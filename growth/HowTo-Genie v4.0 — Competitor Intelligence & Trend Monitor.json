    {
      "parameters": {
        "jsCode": "const all = $input.all();\nconst list = [];\nfor (const item of all) {\n  if (item.json.error && item.json.items && item.json.items.length === 0) continue;\n  if (item.json.url !== undefined && item.json.url) list.push(item.json);\n  else if (Array.isArray(item.json.items)) list.push(...item.json.items.filter(x => x && x.url));\n}\nconst byUrl = new Map();\nfor (const r of list) {\n  const url = (r.url || '').trim();\n  if (!url) continue;\n  const existing = byUrl.get(url);\n  const date = r.published || r.detected_at || '';\n  if (!existing || (date > (existing.published || existing.detected_at || ''))) byUrl.set(url, r);\n}\nconst sorted = Array.from(byUrl.values()).sort((a, b) => {\n  const da = a.published || a.detected_at || '';\n  const db = b.published || b.detected_at || '';\n  return db.localeCompare(da);\n}).slice(0, 500);\nreturn sorted.map(r => ({ json: { title: r.title || '', url: r.url || '', source: r.source || '', published: r.published || '', detected_at: r.detected_at || '' } }));"
      },
