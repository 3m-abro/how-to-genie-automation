    {
      "parameters": {
        "jsCode": "// Parse Google Trends (API returns )]}' prefix)\nconst raw = String($input.first().json).replace(/^\\)\\]\\}\\'\\n/, '');\nlet trends;\ntry {\n  trends = JSON.parse(raw);\n} catch(e) {\n  return [];\n}\n\nconst trendingSearches = trends?.default?.trendingSearchesDays?.[0]?.trendingSearches || [];\n\nreturn trendingSearches.slice(0, 20).map(trend => ({\n  json: {\n    source: 'google_trends',\n    title: trend.title?.query || '',\n    traffic: trend.formattedTraffic || '',\n    articles: trend.articles?.length || 0,\n    url: trend.articles?.[0]?.url || '',\n    snippet: trend.articles?.[0]?.snippet || '',\n    detected_at: new Date().toISOString()\n  }\n}));"
      },
