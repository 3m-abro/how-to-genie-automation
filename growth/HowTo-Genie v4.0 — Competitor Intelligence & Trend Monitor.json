    {
      "parameters": {
        "jsCode": "const config = $input.first().json;\nconst rssRaw = (config.COMPETITOR_RSS_FEEDS || '').toString().trim();\nconst redditRaw = (config.REDDIT_SUBREDDITS || '').toString().trim();\nconst rssUrls = rssRaw ? rssRaw.split(',').map(s => s.trim()).filter(Boolean) : [];\nconst subreddits = redditRaw ? redditRaw.split(',').map(s => s.trim()).filter(Boolean) : [];\nconst normalized = subreddits.map(s => /^r\\//.test(s) ? s : 'r/' + s);\nif (rssUrls.length === 0 && normalized.length === 0) {\n  return [{ json: { no_sources: true } }];\n}\nconst out = [];\nrssUrls.forEach(url => out.push({ json: { type: 'rss', url } }));\nnormalized.forEach(sub => out.push({ json: { type: 'reddit', subreddit: sub } }));\nreturn out;"
      },
