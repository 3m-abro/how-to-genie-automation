      "id": "eb7d4867-200f-4ccc-86f9-e9cda4c0b6d7",
      "typeVersion": 4.1,
      "notes": "Fetches latest posts from competitor blogs via RSS."
    },
    {
      "parameters": {
        "jsCode": "const all = $input.all();\nconst out = [];\nfor (let i = 0; i < all.length; i++) {\n  const xml = all[i].json.body || all[i].json;\n  const feedUrl = typeof $('🔀 Route by Type').item(i).json !== 'undefined' ? $('🔀 Route by Type').item(i).json.url : '';\n  const source = feedUrl || 'rss';\n  const itemMatches = String(xml).match(/<item[^>]*>([\\s\\S]*?)<\\/item>/gi) || [];\n  itemMatches.slice(0, 10).forEach((item) => {\n    const title = (item.match(/<title[^>]*><!\\[CDATA\\[([^\\]]+)\\]\\]><\\/title>/) || item.match(/<title[^>]*>([^<]+)<\\/title>/))?.[1] || '';\n    const link = (item.match(/<link[^>]*>([^<]+)<\\/link>/))?.[1] || '';\n    const pubDate = (item.match(/<pubDate[^>]*>([^<]+)<\\/pubDate>/))?.[1] || '';\n    const description = (item.match(/<description[^>]*><!\\[CDATA\\[([^\\]]+)\\]\\]><\\/description>/) || item.match(/<description[^>]*>([^<]+)<\\/description>/))?.[1] || '';\n    out.push({ json: { source, title: title.trim(), url: link.trim(), published: pubDate, detected_at: new Date().toISOString() } });\n  });\n}\nreturn out.length ? out : [{ json: { source: 'rss', title: '', url: '', published: '', detected_at: new Date().toISOString() } }];"
      },
