{
  "name": "HowTo-Genie v4.0 — Viral Content Amplifier Engine",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 */6 * * *"
            }
          ]
        }
      },
      "name": "📊 Performance Monitor (Every 6 Hours)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [
        -1104,
        48
      ],
      "id": "4c617737-5322-4093-96c5-f672a4aa5058",
      "typeVersion": 1,
      "notes": "Checks Google Analytics + WordPress stats every 6 hours for viral signals."
    },
    {
      "parameters": {
        "url": "https://analyticsdata.googleapis.com/v1beta/properties/YOUR_GA4_PROPERTY_ID:runReport",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_GOOGLE_ANALYTICS_TOKEN"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"dateRanges\": [{ \"startDate\": \"7daysAgo\", \"endDate\": \"today\" }],\n  \"dimensions\": [{ \"name\": \"pagePath\" }, { \"name\": \"pageTitle\" }],\n  \"metrics\": [\n    { \"name\": \"screenPageViews\" },\n    { \"name\": \"averageSessionDuration\" },\n    { \"name\": \"engagementRate\" },\n    { \"name\": \"bounceRate\" }\n  ],\n  \"orderBys\": [{ \"metric\": { \"metricName\": \"screenPageViews\" }, \"desc\": true }],\n  \"limit\": 50\n}",
        "options": {}
      },
      "name": "📈 Fetch GA4 Performance Data",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        -912,
        48
      ],
      "id": "3f81fa1d-bd18-49bc-bdc9-80ad6b4e176d",
      "typeVersion": 4.1,
      "notes": "Google Analytics 4 Data API. Returns top 50 performing pages from last 7 days."
    },
    {
      "parameters": {
        "url": "https://www.googleapis.com/webmasters/v3/sites/https%3A%2F%2Fhowtogenie.com%2F/searchAnalytics/query",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_GOOGLE_SEARCH_CONSOLE_TOKEN"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"startDate\": \"{{ $now.minus({days: 7}).toFormat('yyyy-MM-dd') }}\",\n  \"endDate\": \"{{ $now.toFormat('yyyy-MM-dd') }}\",\n  \"dimensions\": [\"page\", \"query\"],\n  \"rowLimit\": 50,\n  \"aggregationType\": \"byPage\"\n}",
        "options": {}
      },
      "name": "🔍 Fetch Search Console Data",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        -912,
        192
      ],
      "id": "dc57c27a-d9dd-4a19-9eaa-dcaba4c8f46d",
      "typeVersion": 4.1,
      "notes": "Google Search Console API. Shows which keywords are driving traffic."
    },
    {
      "parameters": {
        "jsCode": "// Combine GA4 + GSC data and identify viral candidates\nconst ga4Data = $('Fetch GA4 Performance Data').item.json.rows || [];\nconst gscData = $('Fetch Search Console Data').item.json.rows || [];\n\nconst viralCandidates = [];\n\nga4Data.forEach(row => {\n  const pagePath = row.dimensionValues[0]?.value || '';\n  const pageTitle = row.dimensionValues[1]?.value || '';\n  const pageViews = parseInt(row.metricValues[0]?.value || 0);\n  const avgDuration = parseFloat(row.metricValues[1]?.value || 0);\n  const engagementRate = parseFloat(row.metricValues[2]?.value || 0);\n  const bounceRate = parseFloat(row.metricValues[3]?.value || 0);\n  \n  // Find matching GSC data\n  const gscMatch = gscData.find(g => g.keys[0] === pagePath);\n  const clicks = gscMatch?.clicks || 0;\n  const impressions = gscMatch?.impressions || 0;\n  const ctr = gscMatch?.ctr || 0;\n  const position = gscMatch?.position || 100;\n  \n  // VIRAL DETECTION CRITERIA\n  const isViral = \n    pageViews >= 10000 || // 10K+ views in 7 days\n    (pageViews >= 5000 && engagementRate > 0.08) || // 5K+ views + 8%+ engagement\n    (clicks >= 2000 && position <= 10); // Ranking top 10 with good traffic\n  \n  if (isViral && !pagePath.includes('/page/') && pagePath.length > 10) {\n    viralCandidates.push({\n      page_path: pagePath,\n      page_title: pageTitle,\n      page_url: 'https://howtogenie.com' + pagePath,\n      metrics: {\n        views_7d: pageViews,\n        engagement_rate: (engagementRate * 100).toFixed(2) + '%',\n        avg_duration: Math.round(avgDuration) + 's',\n        bounce_rate: (bounceRate * 100).toFixed(2) + '%',\n        clicks_7d: clicks,\n        impressions_7d: impressions,\n        ctr: (ctr * 100).toFixed(2) + '%',\n        avg_position: position.toFixed(1)\n      },\n      viral_score: Math.round(\n        (pageViews / 1000) * 0.4 + \n        (engagementRate * 100) * 0.3 + \n        (100 - position) * 0.2 + \n        (ctr * 1000) * 0.1\n      ),\n      detected_at: new Date().toISOString()\n    });\n  }\n});\n\n// Sort by viral score\nviralCandidates.sort((a, b) => b.viral_score - a.viral_score);\n\nreturn viralCandidates.slice(0, 10).map(c => ({ json: c }));"
      },
      "name": "🔥 Detect Viral Content",
      "type": "n8n-nodes-base.code",
      "position": [
        -704,
        128
      ],
      "id": "6ef68a2b-8c35-4abf-91e8-3808c701a723",
      "typeVersion": 2,
      "notes": "Analyzes performance data and identifies top 10 viral candidates."
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{ $json.viral_score }}",
              "operation": "largerEqual",
              "value2": 50
            }
          ]
        }
      },
      "name": "🚀 Viral Score ≥ 50?",
      "type": "n8n-nodes-base.if",
      "position": [
        -512,
        128
      ],
      "id": "b09132d9-7805-4923-81f2-aad21a33f436",
      "typeVersion": 1,
      "notes": "Only amplify content with viral score 50+. Prevents wasting budget on mediocre content."
    },
    {
      "parameters": {
        "model": "llama3.2:latest",
        "options": {
          "temperature": 0.6
        }
      },
      "name": "🎯 AI: Design Amplification Campaign",
      "type": "@n8n/n8n-nodes-langchain.lmChatOllama",
      "position": [
        -304,
        48
      ],
      "id": "0a22847e-9bc8-460c-a420-37eb61c6f48c",
      "typeVersion": 1
    },
    {
      "parameters": {
        "jsCode": "// Parse campaign strategy\nconst raw = $input.first().json.response || '';\nconst viralPost = $input.first().json;\n\nlet campaign;\ntry {\n  const match = raw.match(/```json\\n([\\s\\S]*?)\\n```/) || raw.match(/(\\{[\\s\\S]*\\})/);\n  campaign = JSON.parse(match ? (match[1] || match[0]) : raw);\n} catch(e) {\n  campaign = {\n    campaign_name: 'Amplify: ' + viralPost.page_title,\n    total_budget: 150,\n    parse_error: e.message\n  };\n}\n\nreturn [{\n  json: {\n    ...viralPost,\n    campaign: campaign,\n    campaign_id: 'CAMP_' + Date.now(),\n    campaign_status: 'ready_to_launch',\n    created_at: new Date().toISOString()\n  }\n}];"
      },
      "name": "📋 Parse Campaign Strategy",
      "type": "n8n-nodes-base.code",
      "position": [
        -112,
        48
      ],
      "id": "65114035-e82f-4cd6-ad3c-14529da7dfef",
      "typeVersion": 2
    },
