    {
      "parameters": {
        "jsCode": "// Parse translation and prepare for WordPress MultiSite or subdomain\nconst raw = $input.first().json.response || '';\nconst sourceData = $input.first().json;\n\nlet translation;\ntry {\n  const match = raw.match(/```json\\n([\\s\\S]*?)\\n```/) || raw.match(/(\\{[\\s\\S]*\\})/);\n  translation = JSON.parse(match ? (match[1] || match[0]) : raw);\n} catch(e) {\n  translation = {\n    translated_title: sourceData.title + ' (' + sourceData.target_name + ')',\n    translated_content: sourceData.content,\n    translated_excerpt: sourceData.excerpt,\n    parse_error: e.message\n  };\n}\n\n// Build localized affiliate links\nconst localAffiliateNetworks = {\n  'es': { primary: 'Digistore24', secondary: 'ClickBank', note: 'Spain + LATAM' },\n  'pt-BR': { primary: 'Hotmart', secondary: 'Monetizze', note: 'Brazil-specific networks' },\n  'de': { primary: 'Digistore24', secondary: 'CopeCart', note: 'German market leaders' },\n  'fr': { primary: 'Digistore24', secondary: '1TPE', note: 'French networks' },\n  'hi': { primary: 'vCommission', secondary: 'AdmitAd', note: 'Indian networks' },\n  'id': { primary: 'Ratakan', secondary: 'Involve Asia', note: 'Indonesian networks' },\n  'ar': { primary: 'Admitad', secondary: 'ArabClicks', note: 'Arabic affiliate networks' },\n  'ja': { primary: 'A8.net', secondary: 'ValueCommerce', note: 'Top Japanese networks' }\n};\n\nconst affiliateConfig = localAffiliateNetworks[sourceData.target_language] || \n  { primary: 'ClickBank', secondary: 'JVZoo', note: 'International fallback' };\n\nconst translatedPost = {\n  source_post_id: sourceData.post_id,\n  language_code: sourceData.target_language,\n  language_name: sourceData.target_name,\n  country: sourceData.target_country,\n  subdomain: sourceData.target_subdomain,\n  currency: sourceData.target_currency,\n  \n  title: translation.translated_title,\n  content: translation.translated_content,\n  excerpt: translation.translated_excerpt,\n  meta_description: translation.translated_meta_description,\n  slug: translation.translated_slug,\n  keywords: translation.local_keywords || [],\n  \n  affiliate_networks: affiliateConfig,\n  translation_quality: translation.translation_quality_score || 0,\n  cultural_adaptations: translation.cultural_adaptations_made || [],\n  \n  wp_url: (() => { const config = $('⚙️ Load Config').item.json; const baseUrl = (config.WORDPRESS_URL || 'https://howtogenie.com').replace(/\\/$/, ''); const sub = sourceData.target_subdomain; const key = 'WORDPRESS_URL_' + sub.toUpperCase(); if (config[key]) return (config[key].replace(/\\/$/, '') + '/'); try { const u = new URL(baseUrl); const host = u.host.replace(/^www\\./, ''); return u.protocol + '//' + sub + '.' + host + '/'; } catch(e) { return 'https://' + sub + '.howtogenie.com/'; } })(),\n  hreflang_tag: sourceData.target_language,\n  \n  status: 'ready_to_publish',\n  translated_at: new Date().toISOString()\n};\n\nreturn [{ json: translatedPost }];"
      },
