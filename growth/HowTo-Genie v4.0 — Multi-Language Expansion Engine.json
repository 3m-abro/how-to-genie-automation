        "jsCode": "// Add hreflang tags to ALL versions (critical for international SEO)\nconst allVersions = $input.all().map(item => item.json);\n\nconst hreflangLinks = allVersions.map(v => ({\n  lang: v.language_code,\n  url: `${v.wp_url}${v.slug}`\n}));\n\n// Also add the English original\nhreflangLinks.unshift({\n  lang: 'en',\n  url: $('Fetch English Article').item.json[0]?.link || 'https://howtogenie.com'\n});\n\n// Generate hreflang HTML tags\nconst hreflangHTML = hreflangLinks\n  .map(link => `<link rel=\"alternate\" hreflang=\"${link.lang}\" href=\"${link.url}\" />`)\n  .join('\\n');\n\nreturn [{\n  json: {\n    hreflang_tags: hreflangHTML,\n    total_languages: hreflangLinks.length,\n    languages: hreflangLinks.map(l => l.lang).join(', '),\n    instruction: 'Add these hreflang tags to <head> of ALL language versions for proper SEO'\n  }\n}];"
      },
      "name": "🔗 Generate Hreflang Tags",
