    {
      "parameters": {
        "jsCode": "// Prepare source article data for translation\nconst post = $input.first().json[0] || $input.first().json;\n\nconst cleanContent = (post?.content?.rendered || '')\n  .replace(/<[^>]*>/g, '\\n')\n  .replace(/&nbsp;/g, ' ')\n  .replace(/&amp;/g, '&')\n  .replace(/&lt;/g, '<')\n  .replace(/&gt;/g, '>')\n  .replace(/\\s+/g, ' ')\n  .trim();\n\nconst sourceData = {\n  post_id: post?.id,\n  title: post?.title?.rendered,\n  content: cleanContent,\n  excerpt: post?.excerpt?.rendered?.replace(/<[^>]*>/g, '').trim(),\n  slug: post?.slug,\n  url: post?.link,\n  categories: post?.categories || [],\n  tags: post?.tags || [],\n  featured_image: post?.featured_media,\n  word_count: cleanContent.split(' ').length,\n  meta_description: post?.yoast_meta?.yoast_wpseo_metadesc || '',\n  focus_keyword: post?.yoast_meta?.yoast_wpseo_focuskw || ''\n};\n\n// Target languages with config\nconst targetLanguages = [\n  { code: 'es', name: 'Spanish', country: 'Spain/LATAM', subdomain: 'es', currency: 'EUR/USD', temp: 0.7 },\n  { code: 'pt-BR', name: 'Portuguese', country: 'Brazil', subdomain: 'pt', currency: 'BRL', temp: 0.7 },\n  { code: 'de', name: 'German', country: 'Germany', subdomain: 'de', currency: 'EUR', temp: 0.6 },\n  { code: 'fr', name: 'French', country: 'France', subdomain: 'fr', currency: 'EUR', temp: 0.7 },\n  { code: 'hi', name: 'Hindi', country: 'India', subdomain: 'hi', currency: 'INR', temp: 0.8 },\n  { code: 'id', name: 'Indonesian', country: 'Indonesia', subdomain: 'id', currency: 'IDR', temp: 0.8 },\n  { code: 'ar', name: 'Arabic', country: 'Saudi Arabia/UAE', subdomain: 'ar', currency: 'SAR/AED', temp: 0.7 },\n  { code: 'ja', name: 'Japanese', country: 'Japan', subdomain: 'ja', currency: 'JPY', temp: 0.6 }\n];\n\nreturn targetLanguages.map(lang => ({\n  json: {\n    ...sourceData,\n    target_language: lang.code,\n    target_name: lang.name,\n    target_country: lang.country,\n    target_subdomain: lang.subdomain,\n    target_currency: lang.currency,\n    translation_temp: lang.temp\n  }\n}));"
      },
      "name": "🔀 Split Into 8 Languages",
      "type": "n8n-nodes-base.code",
