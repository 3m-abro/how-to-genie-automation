      "id": "email-04-load-config",
      "name": "⚙️ Load Config",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.2,
      "position": [-640, 176],
      "notes": "Runs core/01_Config_Loader.json for EMAIL_NEWSLETTER_ENABLED, EMAIL_PROVIDER, CONVERTKIT_*, MAILERLITE_*, GOOGLE_SHEET_ID. Replace workflowId if using a different n8n instance. Single-provider (convertkit|mailerlite) from config; ESP sends first welcome and sequence."
    },
    {
      "parameters": {
        "jsCode": "const cfg = $('⚙️ Load Config').item.json;\nconst raw = cfg.EMAIL_NEWSLETTER_ENABLED;\nconst enabled = raw === true || String(raw).toLowerCase() === 'true';\nreturn [{ json: { EMAIL_NEWSLETTER_ENABLED: enabled, config: cfg } }];"
      },
      "id": "email-04-normalize-enable",
      "name": "🔧 Normalize Enable Flag",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-480, 176]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.EMAIL_NEWSLETTER_ENABLED }}",
              "value2": true
            }
          ]
        }
      },
      "name": "📧 Newsletter Enabled?",
      "type": "n8n-nodes-base.if",
      "position": [-320, 176],
      "id": "email-04-if-enabled",
      "typeVersion": 1,
      "notes": "When false: respond 200 and stop (no ESP add). When true: continue to Validate & Tag."
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ success: true, message: 'Thanks for signing up.' }) }}",
        "options": {}
      },
      "name": "📧 Respond (Newsletter Disabled)",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [-320, 340],
      "id": "email-04-respond-disabled",
      "typeVersion": 1,
      "notes": "Webhook responds 200 when EMAIL_NEWSLETTER_ENABLED is false; subscriber is not added to ESP."
    },
    {
      "parameters": {
        "jsCode": "// Validate and enrich subscriber data\nconst body = $input.first().json.body || $input.first().json;\n\nconst email = (body.email || '').toLowerCase().trim();\nconst name = (body.name || body.first_name || 'Friend').trim();\nconst source = body.source || body.utm_source || 'website';\nconst leadMagnet = body.lead_magnet || body.offer || 'free-guide';\nconst articleSlug = body.article_slug || '';\nconst tags = [];\n\n// Auto-tag based on source\nif (source.includes('facebook')) tags.push('source:facebook');\nif (source.includes('instagram')) tags.push('source:instagram');\nif (source.includes('organic')) tags.push('source:organic');\nif (articleSlug) tags.push('content:blog-reader');\nif (leadMagnet) tags.push(`magnet:${leadMagnet}`);\ntags.push('status:new-subscriber');\n\n// Email validation\nconst emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\nif (!emailRegex.test(email)) {\n  return [{ json: { valid: false, error: 'Invalid email', original: body }}];\n}\n\n// Determine welcome sequence based on entry point\nlet sequence = 'general';\nif (articleSlug.includes('affiliate')) sequence = 'affiliate';\nelse if (articleSlug.includes('seo') || articleSlug.includes('blog')) sequence = 'blogging';\nelse if (articleSlug.includes('business')) sequence = 'business';\nelse if (articleSlug.includes('tech') || articleSlug.includes('tool')) sequence = 'tech';\n\nconst subscriber = {\n  valid: true,\n  email,\n  first_name: name.split(' ')[0],\n  full_name: name,\n  source,\n  lead_magnet: leadMagnet,\n  article_slug: articleSlug,\n  tags,\n  sequence,\n  subscribed_at: new Date().toISOString(),\n  ip: $input.first().json.headers?.['x-forwarded-for'] || 'unknown'\n};\n\nreturn [{ json: subscriber }];"
      },
      "name": "🔍 Validate & Tag Subscriber",
      "type": "n8n-nodes-base.code",
      "position": [-160, 176],
      "id": "c0970dea-ab80-4416-835d-924d3d89f86b",
      "typeVersion": 2
    },
    {
      "parameters": {
        "conditions": {
