    {
      "parameters": {
        "jsCode": "// Collect all email content and build sequence payload\nconst subscriber = $('Validate & Tag Subscriber').item.json;\n\nconst parseEmail = (raw) => {\n  try {\n    const match = raw.match(/```json\\n([\\s\\S]*?)\\n```/) || raw.match(/(\\{[\\s\\S]*\\})/);\n    return JSON.parse(match ? (match[1] || match[0]) : raw);\n  } catch(e) { return { error: e.message, raw: raw.substring(0,200) }; }\n};\n\nconst email1 = parseEmail($('AI: Write Welcome Email 1').item.json.response);\nconst email2 = parseEmail($('AI: Write Welcome Email 2').item.json.response);\nconst email3 = parseEmail($('AI: Write Welcome Email 3').item.json.response);\nconst emails45 = parseEmail($('AI: Write Welcome Emails 4+5').item.json.response);\n\nconst sequence = [\n  { ...email1, sequence_position: 1, send_delay_days: 0 },\n  { ...email2, sequence_position: 2, send_delay_days: 2 },\n  { ...email3, sequence_position: 3, send_delay_days: 4 },\n  { ...emails45.email_4, sequence_position: 4 },\n  { ...emails45.email_5, sequence_position: 5 }\n];\n\nreturn sequence.map(email => ({\n  json: {\n    subscriber_email: subscriber.email,\n    subscriber_name: subscriber.first_name,\n    ...email\n  }\n}));"
      },
