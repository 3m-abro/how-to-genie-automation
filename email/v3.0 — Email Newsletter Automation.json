    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.convertkit.com/v3/forms/{{ $('🔧 Normalize Enable Flag').item.json.config.CONVERTKIT_FORM_ID }}/subscribe",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"api_key\": \"{{ $credentials.convertKitApi.apiKey }}\",\n  \"email\": \"{{ $json.email }}\",\n  \"first_name\": \"{{ $json.first_name }}\",\n  \"tags\": {{ JSON.stringify($json.tags) }},\n  \"fields\": {\n    \"source\": \"{{ $json.source }}\",\n    \"sequence\": \"{{ $json.sequence }}\",\n    \"subscribed_at\": \"{{ $json.subscribed_at }}\"\n  }\n}",
        "options": {}
      },
      "name": "📧 Add to ConvertKit",
