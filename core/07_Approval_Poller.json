        "url": "=https://api.telegram.org/bot{{ $vars.TELEGRAM_BOT_TOKEN }}/sendMessage",
        "options": {
          "timeout": 10000
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"chat_id\": \"{{ $vars.TELEGRAM_CHAT_ID }}\", \"text\": \"\ud83d\ude80 <b>Orchestrator Triggered from Backlog</b>\\n\\n\ud83d\udcdd Topic: <b>{{ $('\ud83d\udd0d Find Approved Topic').item.json.topic }}</b>\\n\ud83d\udd11 Keyword: {{ $('\ud83d\udd0d Find Approved Topic').item.json.primary_keyword }}\\n\\nArticle generation started.\", \"parse_mode\": \"HTML\"}"
      }
    },
