        0
      ],
      "parameters": {
        "source": "database",
        "workflowId": {
          "__rl": true,
          "value": "REPLACE_WITH_CONFIG_LOADER_ID",
          "mode": "id"
        },
        "options": {
          "waitForSubWorkflow": true
        }
      }
    },
    {
      "id": "98e39837",
      "name": "\ud83d\udccb Read Backlog",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        400,
        0
      ],
      "parameters": {
        "operation": "read",
        "documentId": {
          "__rl": true,
          "value": "={{ $('\u2699\ufe0f Load Config').item.json.GOOGLE_SHEET_ID }}",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "={{ $('\u2699\ufe0f Load Config').item.json.BLOG_IDEA_TAB || 'Blog Idea Backlog' }}",
          "mode": "name"
        },
        "options": {}
      }
    },
    {
      "id": "74e2324e",
      "name": "\ud83d\udd0d Find Approved Topic",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        600,
        0
      ],
      "parameters": {
        "jsCode": "\nconst rows = $input.all();\nconst approved = rows\n  .map((r, i) => ({ ...r.json, _row: i + 2 }))\n  .filter(r => (r.status || r.Status || '').toLowerCase() === 'approved')\n  .sort((a, b) => (b.combined_score || b.intent_score || 0) - (a.combined_score || a.intent_score || 0));\n\nif (approved.length === 0) {\n  return [{ json: { has_approved: false } }];\n}\n\nconst pick = approved[0];\nreturn [{ json: {\n  has_approved:          true,\n  _row:                  pick._row,\n  topic:                 pick.article_title_suggestion || pick.question || pick.topic || '',\n  primary_keyword:       pick.keyword || pick.primary_keyword || '',\n  niche:                 pick.niche || '',\n  intent_score:          pick.intent_score || pick.combined_score || 7,\n  competition:           pick.competition || 'medium',\n  secondary_keywords:    pick.secondary_keywords || [],\n  affiliate_angle:       pick.affiliate_angle || 'general tools and resources',\n  content_outline:       pick.content_outline || [],\n  is_halal_compliant:    true,\n  not_duplicate:         true,\n  source:                'backlog_approved',\n  word_count_target:     3000,\n  generated_at:          new Date().toISOString()\n}}];\n",
        "mode": "runOnceForAllItems"
      }
    },
    {
      "id": "8d7a3c82",
      "name": "\u2705 Topic Approved?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        800,
        0
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "ba7caace",
              "leftValue": "={{ $json.has_approved }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      }
    },
    {
      "id": "3bccdfeb",
      "name": "\ud83d\udcdd Mark as In Progress",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1000,
        0
      ],
      "parameters": {
        "jsCode": "\nconst row = $('\ud83d\udd0d Find Approved Topic').item.json._row;\nreturn [{ json: {\n  Row_Number: row,\n  status:     'In Progress',\n  Status:     'In Progress'\n}}];\n",
        "mode": "runOnceForAllItems"
      }
    },
    {
      "id": "fde372f8",
      "name": "\ud83d\udcca Update Backlog Status",
