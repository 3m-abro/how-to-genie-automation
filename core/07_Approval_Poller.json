    },
    {
      "id": "aa63166f",
      "name": "\ud83d\udce6 Package Topic for Orchestrator",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1400,
        0
      ],
      "parameters": {
        "jsCode": "\nconst t = $('\ud83d\udd0d Find Approved Topic').item.json;\nreturn [{ json: {\n  approved_topic: {\n    topic:              t.topic,\n    primary_keyword:    t.primary_keyword,\n    secondary_keywords: t.secondary_keywords || [],\n    affiliate_angle:    t.affiliate_angle,\n    content_outline:    t.content_outline || [],\n    word_count_target:  t.word_count_target || 3000,\n    is_halal_compliant: true,\n    not_duplicate:      true,\n    generated_at:       t.generated_at,\n    source:             'backlog_approved'\n  }\n}}];\n",
        "mode": "runOnceForAllItems"
      }
    },
    {
      "id": "f8ee6ce0",
      "name": "\ud83d\ude80 Fire Orchestrator",
      "type": "n8n-nodes-base.executeWorkflow",
