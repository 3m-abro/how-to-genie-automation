      "id": "c86f4df0-e676-49d4-b6d0-12356407ae48",
      "name": "🔍 ATP via RapidAPI",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1120,
        -96
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "\nconst keyword = $('✂️ Split by Keyword').item.json.Keyword || '';\nconst niche   = $('✂️ Split by Keyword').item.json.Niche   || '';\nconst raw     = $input.first().json;\n\nconst atp_questions = [];\n\n// ATP returns data.questions, data.prepositions, data.comparisons arrays\nconst sections = ['questions', 'prepositions', 'comparisons'];\nfor (const section of sections) {\n  const items = raw?.data?.[section] || raw?.[section] || [];\n  for (const item of items) {\n    const q = item?.query || item?.string || item?.label || '';\n    if (q && q.length > 5) atp_questions.push({ text: q, source: 'ATP_' + section });\n  }\n}\n\nreturn [{ json: { keyword, niche, atp_questions } }];\n"
      },
      "id": "dd31bd90-2659-44e4-984b-c8fa0aeb7f45",
      "name": "📥 Parse ATP Questions",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1344,
        -96
      ]
    },
    {
      "parameters": {
        "url": "=http://suggestqueries.google.com/complete/search?client=firefox&q=how+to+{{ encodeURIComponent($json.keyword) }}",
        "options": {
          "timeout": 10000
        }
      },
      "id": "586da512-1ade-4ab9-8fda-f7e274807494",
      "name": "🔍 Google Autocomplete",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1568,
        -96
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "\nconst prev      = $('📥 Parse ATP Questions').item.json;\nconst raw       = $input.first().json;\nconst google_qs = [];\n\n// Google returns [query, [suggestions, ...]]\nconst suggestions = Array.isArray(raw) ? raw[1] || [] : [];\nfor (const s of suggestions) {\n  if (typeof s === 'string' && s.length > 5) {\n    google_qs.push({ text: s, source: 'Google_Autocomplete' });\n  }\n}\n\n// Also add common question prefix variants from the raw response\nreturn [{ json: { ...prev, google_questions: google_qs } }];\n"
      },
      "id": "881b1721-9c8b-436f-83a1-cad87a5c250a",
      "name": "📥 Parse Google Suggestions",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1792,
        -96
      ]
    },
    {
      "parameters": {
        "url": "=https://www.reddit.com/search.json?q={{ encodeURIComponent($json.keyword) }}&sort=hot&t=month&limit=15",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "User-Agent",
              "value": "HowToGenie/1.0"
            }
          ]
        },
        "options": {
          "timeout": 10000
        }
      },
      "id": "83564c4d-d62f-4079-bba8-9a09fc75ccf5",
      "name": "🔍 Reddit Search",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        2016,
        -96
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "\nconst prev    = $('📥 Parse Google Suggestions').item.json;\nconst raw     = $input.first().json;\n\nconst reddit_qs = [];\nconst posts = raw?.data?.children || [];\nfor (const post of posts) {\n  const score = post?.data?.score || 0;\n  const title = post?.data?.title || '';\n  if (score >= 20 && title.length > 10) {\n    reddit_qs.push({ text: title, source: 'Reddit', score });\n  }\n}\n\nconst all_questions = [\n  ...(prev.atp_questions    || []),\n  ...(prev.google_questions || []),\n  ...reddit_qs\n];\n\n// Deduplicate by normalised text\nconst seen = new Set();\nconst deduped = all_questions.filter(q => {\n  const key = q.text.toLowerCase().replace(/[^a-z0-9 ]/g,'').trim();\n  if (seen.has(key)) return false;\n  seen.add(key);\n  return true;\n});\n\nreturn [{ json: { ...prev, reddit_questions: reddit_qs, all_questions: deduped, total: deduped.length } }];\n"
      },
      "id": "187bdf2d-f188-456d-8bc9-3205ed39d734",
      "name": "📥 Merge All Sources",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2240,
        -96
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "\nconst prev    = $('📥 Merge All Sources').item.json;\nconst raw     = $input.first().json.message?.content || '[]';\n\nlet scored = [];\ntry {\n  const match = raw.match(/\\[([\\s\\S]*?)\\](?!\\s*[a-z])/i);\n  scored = JSON.parse(match ? '[' + match[1] + ']' : raw);\n} catch(e) {\n  // fallback: return raw questions with default scores\n  scored = (prev.all_questions || []).slice(0, 10).map(q => ({\n    question: q.text,\n    intent_score: 5,\n    affiliate_potential: 5,\n    competition: 'medium',\n    halal_compliant: true,\n    article_title_suggestion: q.text,\n    parse_error: e.message\n  }));\n}\n\n// Filter halal, add metadata\nconst valid = scored\n  .filter(q => q.halal_compliant !== false)\n  .map(q => ({\n    ...q,\n    combined_score: ((q.intent_score || 5) + (q.affiliate_potential || 5)) / 2,\n    keyword: prev.keyword,\n    niche: prev.niche,\n    source: 'multi-source',\n    date_found: new Date().toISOString().split('T')[0],\n    status: 'New'\n  }))\n  .sort((a, b) => b.combined_score - a.combined_score);\n\n// Return one item per question for Google Sheets append\nreturn valid.slice(0, 8).map(q => ({ json: q }));\n"
      },
