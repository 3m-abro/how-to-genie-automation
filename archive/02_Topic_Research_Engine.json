    {
      "parameters": {
        "jsCode": "\nconst cfg    = $('⚙️ Load Config').item.json;\nconst items  = $input.all();\n\n// Sort all questions across all keywords by combined_score\nconst sorted = [...items]\n  .sort((a, b) => (b.json.combined_score || 0) - (a.json.combined_score || 0))\n  .slice(0, 10);\n\nconst lines = sorted.map((item, i) => {\n  const q = item.json;\n  return `${i+1}. <b>${q.article_title_suggestion || q.question}</b>\\n   Keyword: ${q.keyword} | Score: ${q.combined_score?.toFixed(1)} | Competition: ${q.competition}`;\n});\n\nconst msg = `🔍 <b>HowTo-Genie: Daily Topic Digest</b>\\n📅 ${new Date().toLocaleDateString('en-MY', {timeZone: cfg.TIMEZONE || 'Asia/Kuala_Lumpur'})}\\n\\n${lines.join('\\n\\n')}\\n\\n✅ Open the Blog Idea Backlog tab, change one row Status to <b>Approved</b> to trigger today\\'s article.`;\n\nreturn [{ json: { telegram_message: msg, chat_id: cfg.TELEGRAM_CHAT_ID } }];\n"
      },
