    {
      "parameters": {
        "jsCode": "// Parse social media content\nconst socialResponse = $input.first().json.response;\n\nlet socialPosts;\ntry {\n  const jsonMatch = socialResponse.match(/```json\\n([\\s\\S]*?)\\n```/) || \n                    socialResponse.match(/\\{[\\s\\S]*\\}/);\n  \n  if (jsonMatch) {\n    socialPosts = JSON.parse(jsonMatch[1] || jsonMatch[0]);\n  } else {\n    socialPosts = JSON.parse(socialResponse);\n  }\n  \n  // Create separate items for each platform\n  return [\n    { \n      json: { \n        platform: 'twitter', \n        content: socialPosts.twitter.text,\n        hashtags: socialPosts.twitter.hashtags,\n        blog_url: $('Publish to WordPress').item.json.link\n      } \n    },\n    { \n      json: { \n        platform: 'linkedin', \n        content: socialPosts.linkedin.text,\n        blog_url: $('Publish to WordPress').item.json.link\n      } \n    },\n    { \n      json: { \n        platform: 'facebook', \n        content: socialPosts.facebook.text,\n        blog_url: $('Publish to WordPress').item.json.link\n      } \n    }\n  ];\n  \n} catch (error) {\n  return [{\n    json: {\n      platform: 'error',\n      error: error.message\n    }\n  }];\n}"
      },
