    {
      "parameters": {
        "jsCode": "// Parse SEO agent output and prepare for publishing\nconst seoResponse = $input.first().json.response;\n\nlet optimizedData;\ntry {\n  const jsonMatch = seoResponse.match(/```json\\n([\\s\\S]*?)\\n```/) || \n                    seoResponse.match(/\\{[\\s\\S]*\\}/);\n  \n  if (jsonMatch) {\n    optimizedData = JSON.parse(jsonMatch[1] || jsonMatch[0]);\n  } else {\n    optimizedData = JSON.parse(seoResponse);\n  }\n  \n  // Prepare WordPress-ready payload\n  const wpPayload = {\n    title: optimizedData.seo.title,\n    content: optimizedData.optimized_content,\n    slug: optimizedData.seo.slug,\n    status: 'draft', // Change to 'publish' when ready\n    categories: optimizedData.seo.categories,\n    tags: optimizedData.seo.tags,\n    meta: {\n      description: optimizedData.seo.meta_description,\n      focus_keyword: optimizedData.seo.focus_keyword\n    },\n    featured_image_alt: optimizedData.seo.image_alt_texts[0],\n    monetization: optimizedData.monetization,\n    published_at: new Date().toISOString()\n  };\n  \n  return [{ json: wpPayload }];\n  \n} catch (error) {\n  // Return original content if parsing fails\n  return [{\n    json: {\n      title: $('Parse & Validate Topic').item.json.topic,\n      content: $('Agent 2: Content Writer').item.json.response,\n      status: 'draft',\n      error: error.message\n    }\n  }];\n}"
      },
