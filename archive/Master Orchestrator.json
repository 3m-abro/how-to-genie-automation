    {
      "parameters": {
        "jsCode": "// Parse the AI response and validate\nconst aiResponse = $input.first().json.response;\n\nlet topicData;\ntry {\n  // Extract JSON from markdown code blocks if present\n  const jsonMatch = aiResponse.match(/```json\\n([\\s\\S]*?)\\n```/) || \n                    aiResponse.match(/\\{[\\s\\S]*\\}/);\n  \n  if (jsonMatch) {\n    topicData = JSON.parse(jsonMatch[1] || jsonMatch[0]);\n  } else {\n    topicData = JSON.parse(aiResponse);\n  }\n  \n  // Validate required fields\n  if (!topicData.topic || !topicData.primary_keyword) {\n    throw new Error('Missing required fields');\n  }\n  \n  // Add metadata\n  topicData.generated_at = new Date().toISOString();\n  topicData.status = 'pending_approval';\n  topicData.workflow_id = $workflow.id;\n  \n  return [{ json: topicData }];\n  \n} catch (error) {\n  // If parsing fails, create a fallback topic\n  return [{\n    json: {\n      topic: \"How to Start a Profitable Blog in 2024\",\n      primary_keyword: \"start a blog\",\n      secondary_keywords: [\"blogging for beginners\", \"make money blogging\"],\n      search_volume_estimate: \"high\",\n      competition: \"medium\",\n      affiliate_products: [],\n      monetization_potential: \"high\",\n      content_angle: \"Step-by-step guide with monetization focus\",\n      generated_at: new Date().toISOString(),\n      status: 'fallback_topic',\n      error: error.message\n    }\n  }];\n}"
      },
      "name": "Parse & Validate Topic",
      "type": "n8n-nodes-base.code",
