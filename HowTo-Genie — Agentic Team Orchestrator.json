    {
      "id": "code-add-meta",
      "name": "Add Orchestration Meta",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [960, 0],
      "parameters": {
        "jsCode": "const ctx = $('Set Context').item.json;\nconst item = $input.first().json;\nreturn [{\n  json: {\n    ...item,\n    workflowName: ctx.runType,\n    runType: ctx.runType,\n    runHour: ctx.runHour,\n    timestamp: ctx.timestamp,\n    date: ctx.date,\n    status: ctx.runType === 'none' ? 'skipped' : 'completed'\n  }\n}];"
      }
    },
    {
      "id": "sheets-log",
      "name": "Log to Google Sheets",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.2,
      "position": [1200, 0],
      "parameters": {
        "operation": "append",
        "documentId": { "__rl": true, "mode": "id", "value": "YOUR_ORCHESTRATOR_LOG_SHEET_ID" },
        "sheetName": { "__rl": true, "mode": "name", "value": "Agentic Team Log" },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Date": "={{ $json.date }}",
            "Run Hour": "={{ $json.runHour }}",
            "Agent": "={{ $json.runType }}",
            "Status": "={{ $json.status }}",
            "Timestamp": "={{ $json.timestamp }}"
          }
        },
        "options": {}
      },
      "notes": "Optional. Set documentId/sheetName or disable to skip logging."
    }
