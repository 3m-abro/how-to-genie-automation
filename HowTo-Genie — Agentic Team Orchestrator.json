{
  "name": "HowTo-Genie — Agentic Team Orchestrator",
  "nodes": [
    {
      "id": "trigger-agentic",
      "name": "Schedule — Agentic Team",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [0, 0],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 3,5,6,8,9,10,12,14,15,16,18,21 * * *"
            }
          ]
        }
      },
      "notes": "Runs at 3,5,6,8,9,10,12,14,15,16,18,21. Set Context picks which agent runs."
    },
    {
      "id": "code-set-context",
      "name": "Set Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [240, 0],
      "parameters": {
        "jsCode": "const now = new Date();\nconst hour = now.getHours();\nconst day = now.getDay();\nconst isTuesday = day === 2;\nconst isSunday = day === 0;\n\nlet runType = 'none';\nif (hour === 3 && isSunday) runType = 'seo';\nelse if (hour === 5) runType = 'islamic';\nelse if (hour === 6) runType = 'ab_test';\nelse if (hour === 8) runType = 'main';\nelse if (hour === 9) runType = isTuesday ? 'email' : 'competitor';\nelse if (hour === 10) runType = 'whatsapp';\nelse if (hour === 12) runType = 'repurpose';\nelse if (hour === 14) runType = 'multilang';\nelse if (hour === 15 || hour === 21) runType = 'competitor';\nelse if (hour === 16) runType = 'voice';\nelse if (hour === 18) runType = 'ab_test';\n\nreturn [{\n  json: {\n    runHour: hour,\n    runDay: day,\n    runType,\n    timestamp: now.toISOString(),\n    date: now.toISOString().split('T')[0]\n  }\n}];"
      },
      "notes": "Maps hour/day to runType. Replace workflow IDs below with your n8n workflow IDs."
    },
    {
      "id": "switch-route",
      "name": "Route by Agent",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 2,
      "position": [480, 0],
      "parameters": {
        "mode": "expression",
        "outputNumber": 13,
        "outputIndexExpression": "={{ $json.runType === 'islamic' ? 0 : $json.runType === 'ab_test' ? 1 : $json.runType === 'main' ? 2 : $json.runType === 'email' ? 3 : $json.runType === 'whatsapp' ? 4 : $json.runType === 'repurpose' ? 5 : $json.runType === 'video' ? 6 : $json.runType === 'multilang' ? 7 : $json.runType === 'competitor' ? 8 : $json.runType === 'viral' ? 9 : $json.runType === 'voice' ? 10 : $json.runType === 'seo' ? 11 : 12 }}",
        "options": {}
      },
      "notes": "Outputs 0-11 = agent, 12 = none. If your n8n version uses different param names, set Mode to Expression, Number of Outputs = 13, and paste the expression from the note in README."
    },
    {
      "id": "exec-islamic",
      "name": "Exec: Islamic Content",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.1,
      "position": [720, -600],
      "parameters": {
        "source": "database",
        "workflowId": "REPLACE_WITH_ISLAMIC_ENGINE_ID",
        "mode": "once",
        "options": { "waitForSubWorkflow": true }
      }
    },
